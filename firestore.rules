rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    // Check if user is an admin by checking their role in /users or by specific email
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == 'eskander.ragy@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for 'userPrayers' collection
    match /userPrayers/{prayerId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Rules for 'favoriteVerses' collection
    match /favoriteVerses/{favoriteId} {
      allow read, delete: if isAuth() && (resource == null || resource.data.uid == request.auth.uid || favoriteId.startsWith(request.auth.uid + "_") || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && favoriteId.startsWith(request.auth.uid + "_");
    }

    // Rules for 'settings' collection (user-specific configuration)
    match /settings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
